{
  "name": "@codingskuy/coding-school",
  "version": "1.0.1",
  "description": "CodingSchool — Learn Software Engineering with AI, not From AI. OpenCode plugin mentor.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tui": {
      "import": "./dist/tui.js",
      "types": "./dist/tui.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build src/index.ts src/tui.ts --outdir dist --external @opencode-ai/plugin --external @opentui/solid --target node && tsc --emitDeclarationOnly --outDir dist",
    "build:quick": "bun build src/index.ts --outdir dist --external @opencode-ai/plugin --target node",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.0.0",
    "date-fns": "^3.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@opentui/core": "0.4.3",
    "@opentui/solid": "0.4.3",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "opencode",
    "plugin",
    "coding-school",
    "mentor",
    "learning",
    "tutorial"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codingskuy/coding-school.git"
  },
  "homepage": "https://github.com/codingskuy/coding-school#readme",
  "bugs": {
    "url": "https://github.com/codingskuy/coding-school/issues"
  }
}
